<Window x:Class="SsmsRestoreDrop.UI.RestoreDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:SsmsRestoreDrop.UI"
        mc:Ignorable="d"
        Title="Restore Database from Backup"
        Width="820" MinWidth="640"
        Height="820" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <Style TargetType="GroupBox">
            <Setter Property="Margin"  Value="0,4,0,4"/>
            <Setter Property="Padding" Value="6,4,6,6"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding"           Value="0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalAlignment"       Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height"                  Value="24"/>
            <Setter Property="Padding"                 Value="2,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="70"/>
            <Setter Property="Height"  Value="24"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"            Value="0,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Source files -->
            <RowDefinition Height="Auto"/>  <!-- Connection + target database -->
            <RowDefinition Height="Auto"/>  <!-- Backup sets -->
            <RowDefinition Height="Auto"/>  <!-- File relocation -->
            <RowDefinition Height="Auto"/>  <!-- Options -->
            <RowDefinition Height="Auto"/>  <!-- Status / progress -->
            <RowDefinition Height="*" MinHeight="120"/>  <!-- Output pane (script / progress log) -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Source files ────────────────────────────────────────────── -->
        <GroupBox Grid.Row="0" Header="Source backup file(s)">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ListBox Grid.Row="0" Grid.ColumnSpan="3"
                         ItemsSource="{Binding BackupFiles}"
                         Height="64" Margin="0,0,0,4"
                         x:Name="FileListBox"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Grid.Row="1" Grid.Column="1" Content="Add file..."
                        Margin="4,0,4,0" Click="AddFile_Click"/>
                <Button Grid.Row="1" Grid.Column="2" Content="Remove"
                        Click="RemoveFile_Click"/>
            </Grid>
        </GroupBox>

        <!-- ── Connection + target database ───────────────────────────── -->
        <GroupBox Grid.Row="1" Header="Target server &amp; database">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label    Grid.Row="0" Grid.Column="0" Content="Server:"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding Connections}"
                          SelectedItem="{Binding SelectedConnection}"
                          DisplayMemberPath="DisplayName"
                          IsEditable="False" Height="24"/>
                <Button   Grid.Row="0" Grid.Column="2" Content="Connect..."
                          Margin="4,0,0,0" Click="Connect_Click"/>

                <Label   Grid.Row="1" Grid.Column="0" Content="Database:" Margin="0,4,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                         Text="{Binding TargetDatabase, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,4,0,0"/>
            </Grid>
        </GroupBox>

        <!-- ── Backup set picker ───────────────────────────────────────── -->
        <GroupBox Grid.Row="2" Header="Backup set">
            <DataGrid ItemsSource="{Binding BackupSets}"
                      SelectedItem="{Binding SelectedBackupSet}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Height="80"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"           Binding="{Binding Position}"         Width="35"/>
                    <DataGridTextColumn Header="Type"        Binding="{Binding BackupType}"        Width="80"/>
                    <DataGridTextColumn Header="Database"    Binding="{Binding DatabaseName}"      Width="*"/>
                    <DataGridTextColumn Header="Server"      Binding="{Binding ServerName}"        Width="120"/>
                    <DataGridTextColumn Header="Start"       Binding="{Binding BackupStartDate}"   Width="140"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}"       Width="160"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- ── File relocation ────────────────────────────────────────── -->
        <GroupBox Grid.Row="3" Header="File relocation">
            <DataGrid ItemsSource="{Binding RelocateFiles}"
                      AutoGenerateColumns="False"
                      Height="90"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Logical name" Binding="{Binding LogicalName}" IsReadOnly="True" Width="160"/>
                    <DataGridTextColumn Header="Type"         Binding="{Binding FileType}"    IsReadOnly="True" Width="40"/>
                    <DataGridTextColumn Header="Physical path"
                                        Binding="{Binding PhysicalPath, UpdateSourceTrigger=LostFocus}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- ── Options ────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="4" Header="Options">
            <WrapPanel Orientation="Horizontal">
                <CheckBox Content="REPLACE"                    IsChecked="{Binding Replace}"          Margin="0,2,16,2"/>
                <CheckBox Content="NORECOVERY"                 IsChecked="{Binding NoRecovery}"        Margin="0,2,16,2"/>
                <CheckBox Content="STANDBY"                    IsChecked="{Binding Standby}"           Margin="0,2,16,2"/>
                <CheckBox Content="KEEP_CDC"                   IsChecked="{Binding KeepCdc}"           Margin="0,2,16,2"/>
                <CheckBox Content="Close existing connections" IsChecked="{Binding CloseConnections}"  Margin="0,2,16,2"/>
                <CheckBox Content="Take tail-log backup"       IsChecked="{Binding TakeTailLog}"       Margin="0,2,0,2"/>
            </WrapPanel>
        </GroupBox>

        <!-- ── Status / progress bar ─────────────────────────────────── -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,4,0,4">
            <ProgressBar Width="280" Height="14"
                         Minimum="0" Maximum="100"
                         Value="{Binding PercentComplete}"/>
            <TextBlock   Text="{Binding StatusMessage}" VerticalAlignment="Center"
                         Margin="8,0,0,0" FontStyle="Italic" Foreground="#555555"/>
        </StackPanel>

        <!-- ── Output pane (script T-SQL or progress log) ────────────── -->
        <Grid Grid.Row="6" Margin="0,4,0,4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                <TextBlock Text="Output" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="Copy"  Click="CopyOutput_Click"  Margin="12,0,4,0"/>
                <Button Content="Clear" Click="ClearOutput_Click"/>
            </StackPanel>

            <TextBox Grid.Row="1"
                     x:Name="OutputBox"
                     Text="{Binding OutputText, Mode=OneWay}"
                     IsReadOnly="True"
                     IsReadOnlyCaretVisible="True"
                     FontFamily="Consolas"
                     FontSize="12"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     Background="#F8F8F8"
                     Style="{x:Null}">
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Copy"       Command="ApplicationCommands.Copy"/>
                        <MenuItem Header="Select All" Command="ApplicationCommands.SelectAll"/>
                    </ContextMenu>
                </TextBox.ContextMenu>
            </TextBox>
        </Grid>

        <!-- ── Action buttons ─────────────────────────────────────────── -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,6,0,0">
            <Button Content="Refresh"  Click="Refresh_Click"  Margin="0,0,6,0"/>
            <Button Content="Script"   Click="Script_Click"   Margin="0,0,6,0"/>
            <Button Content="Restore"  Click="Restore_Click"  Margin="0,0,6,0"
                    IsDefault="True" FontWeight="SemiBold"/>
            <Button Content="Cancel"   Click="Cancel_Click"   IsCancel="True"/>
        </StackPanel>

    </Grid>
</Window>
