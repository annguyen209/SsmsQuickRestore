<UserControl x:Class="SsmsRestoreDrop.UI.ProgressToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="600"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">

    <DockPanel Margin="6">

        <!-- Header row: database name + progress bar -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="DbNameText"
                       FontWeight="SemiBold" VerticalAlignment="Center"
                       Margin="0,0,8,0"/>

            <ProgressBar Grid.Column="1" x:Name="ProgressBar"
                         Height="14" Minimum="0" Maximum="100" Value="0"
                         VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2" x:Name="PercentText"
                       Width="36" TextAlignment="Right"
                       VerticalAlignment="Center" Margin="6,0,0,0"/>
        </Grid>

        <!-- Toolbar: Clear -->
        <ToolBar DockPanel.Dock="Top" ToolBarTray.IsLocked="True">
            <Button Content="Clear" Click="Clear_Click" ToolTip="Clear log"/>
            <Button Content="Copy all" Click="CopyAll_Click" ToolTip="Copy all messages to clipboard"/>
        </ToolBar>

        <!-- Message log -->
        <ListBox x:Name="MessageList"
                 DockPanel.Dock="Bottom"
                 FontFamily="Consolas" FontSize="12"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Text}"
                               Foreground="{Binding Foreground}"
                               TextWrapping="NoWrap"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</UserControl>
